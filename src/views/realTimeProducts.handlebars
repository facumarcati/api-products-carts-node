<div class="page-header">
  <span class="eyebrow"></span>
  <h1>Gestión de Productos</h1>
</div>

<div class="page-nav">
  <a href="/" class="page-nav-link">
    ← Ver lista de productos
  </a>
</div>

<div class="page-layout">

  <aside class="form-panel">
    <p class="section-label">Agregar Producto</p>

    <form id="productForm">
      <fieldset>

        <div class="field-group">
          <label for="title">Título</label>
          <input type="text" id="title" name="title" required />
        </div>

        <div class="field-group">
          <label for="description">Descripción</label>
          <input type="text" id="description" name="description" required />
        </div>

        <div class="field-row">
          <div class="field-group">
            <label for="code">Código</label>
            <input type="text" id="code" name="code" required />
          </div>
          <div class="field-group">
            <label for="category">Categoría</label>
            <input type="text" id="category" name="category" required />
          </div>
        </div>

        <div class="field-row">
          <div class="field-group">
            <label for="price">Precio</label>
            <input type="number" id="price" name="price" required />
          </div>
          <div class="field-group">
            <label for="stock">Stock</label>
            <input type="number" id="stock" name="stock" required />
          </div>
        </div>

      </fieldset>

      <button class="btn-yellow" type="submit">
        + Agregar Producto
      </button>
    </form>
  </aside>

  <section class="products-panel">
    <p class="section-label">
      Lista de Productos
      <span class="product-count" id="productCount">0</span>
    </p>

    <div class="products-grid" id="productList">
      <div class="empty-state">
        <p>No hay productos registrados.</p>
      </div>
    </div>
  </section>

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/realTimeProducts.js"></script>